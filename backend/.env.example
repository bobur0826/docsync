# backend/.env.example — copy to .env and fill in values

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Supabase → Project Settings → Database → URI (use Session mode pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ─── File Storage (Cloudflare R2) ─────────────────────────────────────────────
# dash.cloudflare.com → R2 → Create bucket → API Tokens → Create token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=docsync-documents

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your Vercel URL after first deploy
FRONTEND_URL=https://your-app.vercel.app

# ─── AI (optional) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
